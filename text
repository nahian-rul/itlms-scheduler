}

function CellEditor({ section, sections, col, data, onClose, onSave }) {
    const [form, setForm] = useState(data || { type: 'Lesson', module: '', content: '', speaker: '', applyToAll: false });
    const availableContent = form.module ? MOCK_CONTENT[MOCK_MODULES.find(m => m.code === form.module)?.id] || [] : [];
    return (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4">
            <Card className="w-full max-w-lg shadow-2xl animate-in fade-in zoom-in duration-200">
                <div className="p-4 bg-slate-50 border-b flex justify-between items-center">
                    <div><h4 className="font-bold text-slate-800">{col.title}</h4><p className="text-xs text-slate-500">Editing Section: <span className="font-bold text-blue-600">{section}</span></p></div>
                    <button onClick={onClose} className="p-1 hover:bg-slate-200 rounded text-slate-400"><X size={20} /></button>
                </div>
                <div className="p-6 space-y-5">
                    <div className="flex bg-slate-100 p-1 rounded-lg">
                        {['Lesson', 'Activity'].map(t => (
                            <button key={t} onClick={() => setForm({ ...form, type: t, content: '', module: '', speaker: '' })} className={`flex-1 py-2 rounded-md text-sm font-bold transition-all ${form.type === t ? 'bg-white shadow-sm text-blue-600' : 'text-slate-500 hover:text-slate-700'}`}>{t}</button>
                        ))}
                    </div>
                    {form.type === 'Lesson' ? (
                        <div className="space-y-4">
                            <div className="grid grid-cols-2 gap-4">
                                <div><label className="text-xs font-black text-slate-400 uppercase mb-1 block">Module</label><select className="w-full p-2.5 border border-slate-200 rounded-md outline-none focus:ring-2 focus:ring-blue-500" value={form.module} onChange={e => setForm({ ...form, module: e.target.value, content: '' })}><option value="">Select Module</option>{MOCK_MODULES.map(m => <option key={m.id} value={m.code}>{m.code} - {m.name}</option>)}</select></div>
                                <div><label className="text-xs font-black text-slate-400 uppercase mb-1 block">Speaker</label><select className="w-full p-2.5 border border-slate-200 rounded-md outline-none focus:ring-2 focus:ring-blue-500" value={form.speaker} onChange={e => setForm({ ...form, speaker: e.target.value })}><option value="">Select Speaker</option>{MOCK_SPEAKERS.map(s => <option key={s} value={s}>{s}</option>)}</select></div>
                            </div>
                            <div><label className="text-xs font-black text-slate-400 uppercase mb-1 block">Content Topic</label><select className="w-full p-2.5 border border-slate-200 rounded-md outline-none focus:ring-2 focus:ring-blue-500 disabled:bg-slate-50" disabled={!form.module} value={form.content} onChange={e => setForm({ ...form, content: e.target.value })}><option value="">Select Content</option>{availableContent.map(c => <option key={c} value={c}>{c}</option>)}</select></div>
                        </div>
                    ) : (
                        <div><label className="text-xs font-black text-slate-400 uppercase mb-1 block">Activity Type</label><select className="w-full p-2.5 border border-slate-200 rounded-md outline-none focus:ring-2 focus:ring-blue-500" value={form.content} onChange={e => setForm({ ...form, content: e.target.value })}><option value="">Select Activity</option>{MOCK_ACTIVITIES.map(a => <option key={a} value={a}>{a}</option>)}</select></div>
                    )}
                    <div className="pt-4 border-t border-slate-100"><label className="flex items-center gap-3 p-4 bg-blue-50 rounded-xl cursor-pointer hover:bg-blue-100 transition-colors group"><input type="checkbox" className="w-5 h-5 rounded border-blue-300 text-blue-600 focus:ring-blue-500" checked={form.applyToAll} onChange={e => setForm({ ...form, applyToAll: e.target.checked })} /><div><div className="text-sm font-black text-blue-900">Merge with all Sections</div><div className="text-[11px] text-blue-600 font-medium italic">Apply to: {sections.join(', ')}</div></div></label></div>
                </div>
                <div className="p-4 bg-slate-50 border-t flex justify-end gap-3"><Button variant="outline" onClick={onClose}>Cancel</Button><Button icon={Save} onClick={() => onSave(form)} disabled={!form.content}>Save Schedule</Button></div>
            </Card>
        </div>
    );
}

// --- Schedule Export Module (Dynamic Footer Updated) ---

function ScheduleExport({ batch, course, date, schedule, onBack }) {
    if (!schedule) return <div className="p-10 text-center font-bold">No data found for this date.</div>;
    const handlePrint = () => window.print();

    return (
        <div className="space-y-6">
            <div className="flex justify-between items-center print:hidden">
                <Button variant="outline" icon={ArrowLeft} onClick={onBack}>Return to Builder</Button>
                <Button icon={Printer} onClick={handlePrint}>Print Now</Button>
            </div>

            <div className="bg-white p-16 mx-auto w-[1200px] border shadow-2xl print:shadow-none print:border-none print:p-0 font-serif overflow-hidden">
                <div className="text-center">
                    <p className="font-bold text-lg uppercase leading-tight">Government of the People's Republic of Bangladesh</p>
                    <p className="font-bold text-lg leading-tight">National Academy for Educational Management (NAEM)</p>
                    <p className="text-xs border-b border-black inline-block px-4 mb-2">Ministry of Education, NAEM Road, Dhanmondi, Dhaka-1205</p>
                    <p className="font-bold text-2xl mt-4">{course.name}</p>
                    <p className="text-sm italic">Duration: {batch.startDate} - {batch.endDate}</p>
                    <h3 className="text-2xl font-black underline mt-6 mb-8 uppercase tracking-widest">Training Schedule</h3>
                </div>

                <div className="flex justify-between items-end mb-1 text-sm font-bold">
                    <div>Date: {date}</div>
                    <div className="text-right">Course Code: {course.code}</div>
                </div>

                <table className="w-full border-collapse border-2 border-black text-[10px]">
                    <thead>
                        <tr>
                            <th className="border border-black p-1 w-24 bg-slate-50 uppercase">Sections</th>
                            {schedule.columns.map(col => (
                                <th key={col.id} className="border border-black p-2 bg-slate-50">
                                    <div className="font-bold uppercase text-xs">{col.title}</div>
                                    <div className="text-[9px] font-normal">{col.startTime} - {col.endTime}</div>
                                </th>
                            ))}
                        </tr>
                    </thead>
                    <tbody>
                        {schedule.sections.map((section) => (
                            <tr key={section} className="h-20">
                                <td className="border border-black p-2 text-center font-bold bg-slate-50/50">{section}</td>
                                {schedule.columns.map(col => {
                                    const cellKey = `${section}_${col.id}`;
                                    const cell = schedule.cells[cellKey];
                                    if (cell?.merged) return null;
                                    let rowSpan = 1;
                                    if (cell?.masterId === cellKey) {
                                        schedule.sections.forEach(s => {
                                            if (s !== section && schedule.cells[`${s}_${col.id}`]?.masterId === cellKey) rowSpan++;
                                        });
                                    }
                                    const isBreak = cell?.content.toLowerCase().includes('break') || cell?.content.toLowerCase().includes('lunch');
                                    return (
                                        <td key={col.id} rowSpan={rowSpan} className={`border border-black p-2 text-center align-middle ${isBreak ? 'bg-slate-100' : ''}`}>
                                            {cell ? (
                                                <div className={`${isBreak ? '[writing-mode:vertical-lr] rotate-180 inline-block font-bold' : ''} ${rowSpan > 1 ? 'flex flex-col items-center justify-center' : ''}`}>
                                                    {cell.module && <div className="font-bold mb-1">ID - {cell.module}</div>}
                                                    <div className={isBreak ? 'text-sm' : 'font-bold'}>{cell.content}</div>
                                                    {cell.speaker && <div className="mt-1 italic border-t border-black/10 pt-1 w-full">{cell.speaker}</div>}
                                                </div>
                                            ) : '—'}
                                        </td>
                                    );
                                })}
                            </tr>
                        ))}
                    </tbody>
                </table>

                {/* Dynamic Guidelines Section (Replaces Static Dress Code) */}
                <div className="mt-8 grid grid-cols-1 gap-2 text-xs font-bold">
                    {schedule.guidelines?.length > 0 ? (
                        schedule.guidelines.map(g => (
                            <div key={g.id} className="flex gap-2">
                                <span className="underline whitespace-nowrap">{g.name}:</span>
                                <span className="italic font-normal">{g.instruction}</span>
                            </div>
                        ))
                    ) : (
                        <div className="italic text-slate-400 font-normal">No specific instructions or dress codes provided.</div>
                    )}
                </div>

                <div className="mt-24 flex justify-end">
                    <div className="text-center min-w-[250px]">
                        <div className="h-12 w-full border-b border-black mb-2 flex items-end justify-center">
                            <span className="text-slate-200 text-2xl font-serif italic">Signature</span>
                        </div>
                        <p className="font-bold uppercase">Course Coordinator</p>
                        <p>NAEM, Dhaka</p>
                    </div>
                </div>
            </div>
        </div>
    );
}