            <Card className="w-full max-w-sm animate-in zoom-in duration-200">
                <div className="p-4 border-b flex justify-between items-center bg-slate-50">
                    <h4 className="font-bold">Edit Column</h4>
                    <button onClick={onClose} className="p-1 hover:bg-slate-200 rounded"><X size={18} /></button>
                </div>
                <div className="p-5 space-y-4">
                    <div><label className="text-xs font-bold text-slate-500 mb-1 block">Title</label><input className="w-full p-2 border rounded-md outline-none focus:ring-2 focus:ring-blue-500" value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} /></div>
                    <div className="grid grid-cols-2 gap-4">
                        <div><label className="text-xs font-bold text-slate-500 mb-1 block">Start Time</label><input type="time" className="w-full p-2 border rounded-md outline-none focus:ring-2 focus:ring-blue-500" value={form.startTime} onChange={e => setForm({ ...form, startTime: e.target.value })} /></div>
